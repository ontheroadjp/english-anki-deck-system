# Deployment target directory on the host. GitHub Actions uses the same
# value from the DEPLOY_PATH repository secret. The CI workflow rsyncs a
# slim payload (only backend/vocabdb, backend/pyproject.toml, and the
# CI-built backend/vocabulary.db) into $DEPLOY_PATH/, preserving .env and
# .venv/. systemd reads $DEPLOY_PATH/.env.
DEPLOY_PATH=REPOSITORY_PATH_ON_SERVER

# Runtime settings for the backend API process. DICT_ENGLISH_DB is resolved
# relative to $DEPLOY_PATH/backend/ (the working directory set by systemd).
DICT_ENGLISH_DB=vocabulary.db
DICT_ENGLISH_HOST=localhost
DICT_ENGLISH_PORT=8001
