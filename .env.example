# Deployment target. GitHub Actions uses the same value from the
# DEPLOY_PATH repository secret; systemd uses the value set in
# server/systemd/dict-english.service to locate this .env file.
DEPLOY_PATH=REPOSITORY_PATH_ON_SERVER

# Runtime settings for the backend API process.
DICT_ENGLISH_DB=vocabulary.db
DICT_ENGLISH_HOST=localhost
DICT_ENGLISH_PORT=8001
