# Deployment target parent directory. GitHub Actions uses the same value
# from the DEPLOY_PATH repository secret; the repository is cloned into
# $DEPLOY_PATH/english and systemd reads $DEPLOY_PATH/english/.env.
DEPLOY_PATH=REPOSITORY_PATH_ON_SERVER

# Runtime settings for the backend API process.
DICT_ENGLISH_DB=vocabulary.db
DICT_ENGLISH_HOST=localhost
DICT_ENGLISH_PORT=8001
